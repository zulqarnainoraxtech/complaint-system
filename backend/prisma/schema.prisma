generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Society ─────────────────────────────────────────────
model Society {
  id          String       @id @default(cuid())
  name        String       @unique
  address     String?
  city        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users       User[]
  departments Department[]
  complaints  Complaint[]

  @@map("societies")
}

// ── User ────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("user") // admin, user, worker, department_head
  societyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society    Society?    @relation(fields: [societyId], references: [id], onDelete: SetNull)
  complaints Complaint[]
  assignments Assignment[]

  @@map("users")
}

// ── Department ──────────────────────────────────────────
model Department {
  id        String   @id @default(cuid())
  name      String
  societyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society    Society?    @relation(fields: [societyId], references: [id], onDelete: SetNull)
  complaints Complaint[]
  workers    Worker[]

  @@unique([name, societyId])
  @@map("departments")
}

// ── Worker ──────────────────────────────────────────────
model Worker {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department  Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  @@map("workers")
}

// ── Complaint ───────────────────────────────────────────
model Complaint {
  id           String   @id @default(cuid())
  title        String
  description  String
  status       String   @default("pending") // pending, in_progress, resolved, rejected
  priority     String   @default("medium")  // low, medium, high, urgent
  userId       String
  departmentId String?
  societyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  society     Society?     @relation(fields: [societyId], references: [id], onDelete: SetNull)
  assignments Assignment[]

  @@map("complaints")
}

// ── Assignment (Worker ↔ Complaint) ─────────────────────
model Assignment {
  id          String   @id @default(cuid())
  complaintId String
  workerId    String?
  userId      String?  // assigned by (admin/dept head)
  note        String?
  status      String   @default("assigned") // assigned, in_progress, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  worker    Worker?   @relation(fields: [workerId], references: [id], onDelete: SetNull)
  assignedBy User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("assignments")
}
